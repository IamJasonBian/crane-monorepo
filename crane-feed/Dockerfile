FROM python:3.12-slim

WORKDIR /app

# Install system deps for Chromium (Playwright) and xvfb for headed mode
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    libwayland-client0 \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

# Install shared lib first for layer caching
COPY crane-shared/ /deps/crane-shared/
RUN pip install --no-cache-dir /deps/crane-shared/

COPY crane-feed/ /app/
RUN pip install --no-cache-dir /app/

# Install Playwright Chromium browser
RUN python -m playwright install chromium

# Use xvfb-run to provide a virtual display for headed Chromium
CMD ["xvfb-run", "--auto-servernum", "--server-args=-screen 0 1920x1080x24", "crane-feed"]
